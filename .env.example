# Obscura — Environment Variables
# Copy this file to .env and fill in the values you need.
# You only need credentials for the backends/plugins you plan to use.

# =============================================================================
# LLM Backends — add credentials for whichever backend(s) you use
# =============================================================================

# GitHub Copilot (default backend)
GITHUB_TOKEN=

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI / Codex
OPENAI_API_KEY=

# Moonshot
MOONSHOT_API_KEY=

# Local LLM (e.g. LM Studio, Ollama)
OBSCURA_LOCALLLM_BASE_URL=http://localhost:1234/v1

# =============================================================================
# Obscura Core
# =============================================================================

OBSCURA_PORT=8080
OBSCURA_LOG_LEVEL=INFO
OBSCURA_OUTPUT_MODE=plain


# Auth (off by default for local dev — enable for production).
# The server refuses to start with OBSCURA_AUTH_ENABLED=false unless it is
# bound to a loopback address (127.0.0.1/::1/localhost) or you explicitly
# set OBSCURA_ALLOW_UNAUTHENTICATED=true to accept the risk of an open
# public endpoint (isolated lab networks only).
OBSCURA_AUTH_ENABLED=false
# OBSCURA_ALLOW_UNAUTHENTICATED=false

# Paranoid subprocess env filtering. Default off — tools inherit os.environ
# normally. Set to 1 to strip all KNOWN_SECRET_NAMES (Supabase, LLM backend
# keys, plugin creds) plus any --force'd keys you've materialised from the
# keyring BEFORE handing the env to run_shell / run_python3 / code_sandbox
# / MCP servers / background tasks / worktree git. A tool that genuinely
# needs one of those keys can still pass it via its own API's env/extras.
# OBSCURA_TOOL_ENV_STRICT=1
#
# Every strict-mode strip event is appended to a JSONL audit log (default
# ~/.obscura/logs/secrets-audit.jsonl). Inspect via:
#   obscura-auth secrets strict-env
#   obscura-auth secrets strict-env --tail 50
#   obscura-auth secrets strict-env --clear
# Override the audit log location:
# OBSCURA_SECRETS_AUDIT_LOG=~/my/custom/audit.jsonl

# Auth is always on. Provide credentials via one of:
#   • API keys below (for scripts / CI / local dev)
#   • Supabase OAuth (for human users — see block below)

# API keys: token:username:scope1,scope2  (semicolon-separate multiple keys)
# OBSCURA_API_KEYS=your-token-here:admin:agent:read,agent:copilot,sessions:manage

# Supabase OAuth — primary identity provider for human users.
# Set SUPABASE_JWT_SECRET (HS256) OR SUPABASE_JWKS_URL (RS256, takes precedence).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=your-project-jwt-secret
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_AUDIENCE=authenticated
# SUPABASE_ISSUER=  # optional; auto-derived from SUPABASE_URL when blank
#
# Prefer the OS keyring on macOS / Windows / Linux desktop:
#   obscura-auth secrets set SUPABASE_URL
#   obscura-auth secrets set SUPABASE_ANON_KEY
#   obscura-auth secrets set SUPABASE_JWT_SECRET          # server only
#   obscura-auth secrets set SUPABASE_SERVICE_ROLE_KEY    # CLI only
# Resolution order: shell env → keyring → Supabase encrypted cloud vault
# → .env files → default. Values the operator exports in their shell (or
# Docker passes via `-e`) always win. Keyring beats .env files, so
# dropping into an unrelated repo with its own .env cannot shadow a value
# you stored via `obscura-auth secrets set`.
# SUPABASE_ANON_KEY=your-project-anon-key
# SUPABASE_SERVICE_ROLE_KEY=  # CLI-only; never deploy to Docker
#
# Encrypted cloud vaults (user_metadata.obscura_vault + obscura_vault_risk).
# Values are always encrypted -- plaintext never leaves your machine.
# Two tiers:
#   - Regular: email-derived Fernet key, zero-friction, works once you're
#     signed in. Good for API keys that you'd rotate freely.
#   - Risky (--risk flag on push): passphrase-derived Fernet key for
#     secrets where you want defense against anyone holding a raw
#     Supabase session. The derived key caches in the OS keyring after
#     the first use; the passphrase itself is never stored.
# Commands:
#   obscura-auth secrets cloud status                           # list inventory
#   obscura-auth secrets cloud push ANTHROPIC_API_KEY           # → regular vault
#   obscura-auth secrets cloud push GH_TOKEN --risk             # → risky vault
#   obscura-auth secrets cloud pull NAME                        # decrypt + save
#   obscura-auth secrets cloud pull-all                         # fresh-machine bulk
#   obscura-auth secrets cloud passphrase set|clear             # manage risky key
#
# User profile (user_metadata.obscura_profile). Plaintext, non-secret
# context: display name, backend defaults, timezone, feature flags,
# last-session continuity, and a list of machines you've registered.
# Machines get a UUID stored at ~/.obscura/machine.id.
#   obscura-auth profile show                                   # all fields
#   obscura-auth profile set default_backend claude             # one field
#   obscura-auth profile unset default_backend                  # clear a field
#   obscura-auth profile device register [--name laptop]        # add this machine
#   obscura-auth profile device list                            # all registered
#   obscura-auth profile device remove <ID>                     # drop stale entry

# Undercover mode — strips AI attribution from commits/PRs (1=on, 0=off)
OBSCURA_UNDERCOVER=1

# =============================================================================
# Vector Memory
# =============================================================================

OBSCURA_VECTOR_MEMORY=on
OBSCURA_VECTOR_BACKEND=qdrant

# Qdrant (leave blank to fall back to SQLite local store)
OBSCURA_QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# =============================================================================
# Agent-to-Agent (A2A)
# =============================================================================

OBSCURA_A2A_ENABLED=true
# OBSCURA_A2A_REDIS_URL=redis://localhost:6379

# =============================================================================
# Plugin credentials — uncomment and fill in plugins you want to activate
# =============================================================================

# Datadog
# DD_API_KEY=
# DD_APP_KEY=
# DD_SITE=datadoghq.com

# GitHub GraphQL
# GITHUB_TOKEN=   (reuse the one above)

# Notion
# NOTION_TOKEN=

# X (Twitter)
# X_BEARER_TOKEN=
# X_ACCESS_TOKEN=

# Shodan
# SHODAN_API_KEY=

# Alpha Vantage
# ALPHAVANTAGE_API_KEY=

# CoinGecko (Pro)
# COINGECKO_API_KEY=

# Grafana
# GRAFANA_URL=http://localhost:3000
# GRAFANA_API_KEY=

# Kubernetes
# KUBECONFIG=~/.kube/config

# FlightAware
# FLIGHTAWARE_API_KEY=

# SEC EDGAR (no key required for public endpoints)

# MarineTraffic
# MARINETRAFFIC_API_KEY=

# HuggingFace
# HF_TOKEN=

# Polygon.io
# POLYGON_API_KEY=

# SecurityTrails
# SECURITYTRAILS_API_KEY=

# Censys
# CENSYS_API_ID=
# CENSYS_API_SECRET=

# M365 / Microsoft Graph
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=

# NATS
# NATS_URL=nats://localhost:4222

# =============================================================================
# Messaging Channels (Telegram, WhatsApp, Slack)
# =============================================================================

# Telegram
# TELEGRAM_BOT_TOKEN=

# Slack
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# =============================================================================
# Telemetry (optional)
# =============================================================================

# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
