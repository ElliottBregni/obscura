# =============================================================================
# Obscura SDK — "batteries included" image (slim + every plugin + providers)
#
# Build:   docker build -f Dockerfile.full -t obscura:full .
# Compare: `Dockerfile` produces obscura:slim (core + server + telemetry only).
#
# This image bakes in:
#   • every `obscura[plugins-all]` pip dep (duckdb, datafusion, huggingface,
#     xdk, notion-client, pycoingecko, datadog-api-client, msal, gws-cli)
#   • every `obscura[anthropic]` provider dep
#   • OS-level binaries that non-pip plugins shell out to (jq, rg, fd, fzf,
#     gitleaks, kubectl) plus node + npx so playwright / m365 work out of box
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1: Builder — resolve the uv workspace with the fat extras set
# -----------------------------------------------------------------------------
FROM python:3.13.5-slim AS builder

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./

# Resolve third-party deps first (cache-friendly — source copy comes next).
RUN uv sync --frozen --no-dev --no-install-project \
        --extra server --extra telemetry --extra plugins-all --extra anthropic

COPY obscura/ obscura/
COPY scripts/ scripts/

RUN uv sync --frozen --no-dev \
        --extra server --extra telemetry --extra plugins-all --extra anthropic

# -----------------------------------------------------------------------------
# Stage 2: Runtime — slim base + binary plugin deps + the built venv
# -----------------------------------------------------------------------------
FROM python:3.13.5-slim AS runtime

# Binary plugin deps — jq, ripgrep, fd, fzf, gitleaks, kubectl, node/npm.
# gh + libpq-dev carry over from the slim image.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        gh ca-certificates libpq-dev curl gnupg \
        nodejs npm \
        jq ripgrep fd-find fzf \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && curl -sSL -o /usr/local/bin/kubectl \
        "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" \
    && chmod +x /usr/local/bin/kubectl \
    && curl -sSL "https://github.com/gitleaks/gitleaks/releases/latest/download/gitleaks_8.18.4_linux_x64.tar.gz" \
        | tar -xz -C /usr/local/bin gitleaks \
    && npm install -g \
        @anthropic-ai/claude-code \
        @pnp/cli-microsoft365 \
        playwright \
    && npx -y playwright install --with-deps chromium \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r obscura && useradd -r -g obscura -d /home/obscura -m obscura

WORKDIR /app

COPY --from=builder /app/.venv /app/.venv
COPY --from=builder /app/obscura obscura/
COPY --from=builder /app/scripts scripts/

RUN find /app/.venv/lib -path "*/site-packages/copilot/bin/copilot" -type f -exec chmod 755 {} \;

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
ENV OBSCURA_HOME=/home/obscura/.obscura

USER obscura
EXPOSE 8080 50051

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import httpx; httpx.get('http://localhost:8080/health').raise_for_status()"

ENTRYPOINT ["python", "-m", "uvicorn", "obscura.server:create_app", "--factory", "--host", "0.0.0.0", "--port", "8080"]
