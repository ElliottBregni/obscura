{
  "manifest_version": 3,
  "name": "Obscura",
  "short_name": "Obscura",
  "description": "Chat with Obscura from any tab. Side-panel agent with optional page context.",
  "version": "0.5.3",
  "minimum_chrome_version": "116",
  "key": "",
  "action": {
    "default_title": "Open Obscura"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "permissions": [
    "sidePanel",
    "nativeMessaging",
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "clipboardRead",
    "clipboardWrite",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/tools/extbridge.user.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["src/content_scripts/extbridge_content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*/*"],
      "js": ["src/content_scripts/extbridge_main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
