# Obsidian metadata
.obsidian/
.DS_Store

# Python
__pycache__/
*.pyc
*.egg-info/
.venv/

# Symlinked repos (tracked in their respective repos)
repos/

# Agent CLI state (synced bidirectionally, user-specific configs)
# Not committed to vault repo (local sync only)
*-cli/

# Package files (MCP servers, plugins, etc.)
**/pkg/
pkg/
*.pkg

# Vault-only folders (can be committed to vault repo if desired)
scratch/
thinking/
_attachments/
scratch/*
thinking/*

