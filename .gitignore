# Python bytecode
__pycache__/
*.pyc

# Obsidian metadata
.obsidian/
.DS_Store

# Symlinked repos (tracked in their respective repos)
repos/
repo/

# Agent system-level symlinks (machine-specific paths)
agents/copilot
agents/claude

# Agent CLI state (synced bidirectionally, user-specific configs)
# Not committed to vault repo (local sync only)
*-cli/

# Package files (MCP servers, plugins, etc.)
**/pkg/
pkg/
*.pkg

# Vault-only folders (can be committed to vault repo if desired)
scratch/
thinking/
_attachments/
scratch/*
thinking/*

crawlers/*
crawlers/

tests/__pycache__
__pycache__
node_modules/