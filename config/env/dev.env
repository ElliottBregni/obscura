# Local development defaults — NEVER source this in prod.
# The dev API key below is publicly known (it's in the source tree) and
# grants admin. Auth is always on; this file pre-loads the public dev key
# so local curls work out of the box. Do not copy these values into any
# non-local env.
OBSCURA_ENV=dev
OBSCURA_SDK_IMAGE=obscura-sdk:local
OBSCURA_WEB_IMAGE=obscura-web-ui:local

# Required for the dev API key below to load.
OBSCURA_DEV_MODE=true
OBSCURA_JWKS_STRICT=false
OBSCURA_JWKS_WAIT_TIMEOUT_SECS=60

OBSCURA_API_KEYS=obscura-dev-key-123:dev-user:admin,agent:copilot,agent:claude,agent:localllm,agent:openai,agent:moonshot,agent:read,sync:write,sessions:manage
OBSCURA_DEFAULT_BACKEND=copilot
OBSCURA_AUTH_MODE=oauth_first
OBSCURA_GITHUB_TOKEN_CMD="python /app/scripts/print_gh_oauth_token.py"
OBSCURA_CLAUDE_TOKEN_CMD=

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=obscura-sdk
OBSCURA_LOG_LEVEL=DEBUG
OBSCURA_LOG_FORMAT=json

OBSCURA_A2A_ENABLED=true
OBSCURA_A2A_REDIS_URL=redis://redis:6379
OBSCURA_A2A_GRPC_PORT=50051

VITE_PROXY_TARGET=http://obscura-sdk:8080
VITE_WS_PROXY_TARGET=ws://obscura-sdk:8080
VITE_DEV_API_KEY=obscura-dev-key-123
VITE_FORCE_DEV_API_KEY=true
CHOKIDAR_USEPOLLING=true
# Local overrides (gitignored)
OBSCURA_QDRANT_MODE=cloud

# ── Auth ──────────────────────────────────────────────────────────────────
# Enforce authentication on /api/* + /mcp/* + /a2a/* routes.
OBSCURA_AUTH_ENABLED=true
# Uncomment to also load the public dev API key for curl testing.
# OBSCURA_DEV_MODE=true

# ── Supabase OAuth — server + CLI ─────────────────────────────────────────
SUPABASE_URL=https://cnwxxlruuuqisjezsgje.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNud3h4bHJ1dXVxaXNqZXpzZ2plIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjQ0NzA2MTgsImV4cCI6MjA4MDA0NjYxOH0.sRtcAhCqD83MlGCKutClRZe6Ca3h3SyeW4IkNGal_eE
# ES256 asymmetric signing via JWKS (rotated 2026-04-23). No shared secret
# on the server; the public key is fetched from Supabase on first validation
# and cached. SUPABASE_JWT_SECRET is intentionally absent.
SUPABASE_JWKS_URL=https://cnwxxlruuuqisjezsgje.supabase.co/auth/v1/.well-known/jwks.json
