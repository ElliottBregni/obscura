{
  "mcpServers": {
    "postman": {
      "command": "npx",
      "args": ["-y", "@postman/postman-mcp-server"],
      "env": {
        "POSTMAN_API_KEY": "${POSTMAN_API_KEY}"
      },
      "tools": [],
      "description": "Postman API testing and collection management"
    },
    "jira": {
      "command": "/Users/bregnie/.nvm/versions/node/v25.2.1/bin/jira-mcp",
      "args": [],
      "env": {
        "JIRA_BASE_URL": "${JIRA_BASE_URL}",
        "JIRA_USER_EMAIL": "${JIRA_USER_EMAIL}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
      },
      "tools": [],
      "description": "Jira project management and issue tracking"
    },
    "auth0": {
      "command": "npx",
      "args": ["-y", "@auth0/auth0-mcp-server", "run"],
      "env": {
        "DEBUG": "auth0-mcp"
      },
      "tools": [],
      "description": "Auth0 identity management and authentication"
    },
    "filesystem": {
      "command": "node",
      "args": ["/Users/elliottbregni/.obscura/mcp-servers/filesystem/dist/index.js", "/Users/elliottbregni/dev"],
      "env": {},
      "tools": [],
      "description": "Secure file operations with access controls - restricted to ~/dev"
    },
    "git": {
      "command": "node",
      "args": ["/Users/elliottbregni/.obscura/mcp-servers/git/dist/index.js"],
      "env": {},
      "tools": [],
      "description": "Git operations - read, search, manipulate repositories"
    },
    "memory": {
      "command": "node",
      "args": ["/Users/elliottbregni/.obscura/mcp-servers/memory/dist/index.js"],
      "env": {},
      "tools": [],
      "description": "Knowledge graph persistent memory (complements Obscura memory)"
    },
    "fetch": {
      "command": "node",
      "args": ["/Users/elliottbregni/.obscura/mcp-servers/fetch/dist/index.js"],
      "env": {},
      "tools": [],
      "description": "Web content fetching with HTML→markdown conversion"
    },
    "sequentialthinking": {
      "command": "node",
      "args": ["/Users/elliottbregni/.obscura/mcp-servers/sequentialthinking/dist/index.js"],
