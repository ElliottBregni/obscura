{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/elliottbregni/dev"
      ],
      "env": {},
      "tools": [],
      "description": "Secure file operations with access controls - restricted to ~/dev"
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/Users/elliottbregni/dev"
      ],
      "env": {},
      "tools": [],
      "description": "Git operations - read, search, manipulate repositories"
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {},
      "tools": [],
      "description": "Knowledge graph persistent memory (complements Obscura memory)"
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {},
      "tools": [],
      "description": "Web content fetching with HTML to markdown conversion"
    },
    "sequentialthinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {},
      "tools": [],
      "description": "Dynamic problem-solving through structured thought sequences"
    },
    "postman": {
      "command": "npx",
      "args": [
        "-y",
        "@postman/postman-mcp-server"
      ],
      "env": {
        "POSTMAN_API_KEY": "${POSTMAN_API_KEY}"
      },
      "tools": [],
      "description": "Postman API testing and collection management"
    },
    "jira": {
      "command": "npx",
      "args": [
        "-y",
        "jira-mcp"
      ],
      "env": {
        "JIRA_BASE_URL": "${JIRA_BASE_URL}",
        "JIRA_USER_EMAIL": "${JIRA_USER_EMAIL}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
      },
      "tools": [],
      "description": "Jira project management and issue tracking"
    },
    "auth0": {
      "command": "npx",
      "args": [
        "-y",
        "@auth0/auth0-mcp-server",
        "run"
      ],
      "env": {
        "DEBUG": "auth0-mcp"
      },
      "tools": [],
      "description": "Auth0 identity management and authentication"
    }
  }
}
