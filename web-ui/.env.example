# Obscura Web UI — Environment Variables Template
# Copy this file to .env and fill in your values

# ── Dev Auth (Local / Offline) ─────────────────────────────────────────────
# Your Obscura API key (format: obscura_<token>)
VITE_DEV_API_KEY=obscura_your_api_key_here

# Set to "true" to auto-login with VITE_DEV_API_KEY (bypasses login screen)
# Use for local dev only — never in production
VITE_FORCE_DEV_API_KEY=true

# ── Proxy Targets ──────────────────────────────────────────────────────────
# Vite dev server proxies /api/* and /ws/* to these targets
VITE_PROXY_TARGET=http://localhost:8080
VITE_WS_PROXY_TARGET=ws://localhost:8080

# ── Online / Production Mode ───────────────────────────────────────────────
# Set this to the deployed Obscura API URL when running without Vite proxy
# (e.g. when the frontend is served as static files in prod)
# VITE_API_URL=https://obscura.yourdomain.com
