#!/bin/bash
# Auto-repair broken symlinks after git operations (merge, rebase, pull)
# Detects if agent target dirs have become real directories and repairs them.
#
# Install: ln -sf ~/FV-Copilot/git-hooks/post-merge .git/hooks/post-merge

VAULT_PATH="$HOME/FV-Copilot"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
REPO_NAME=$(basename "$REPO_ROOT" 2>/dev/null)

if [ -f "$VAULT_PATH/sync.py" ] && [ -n "$REPO_NAME" ]; then
    # Check if any agent target dir is a real directory (not managed per-file symlinks)
    needs_repair=false
    for target in .github .claude .cursor; do
        target_dir="$REPO_ROOT/$target"
        if [ -d "$target_dir" ] && [ ! -L "$target_dir" ]; then
            # Check for real (non-symlink) files inside
            real_files=$(find "$target_dir" -type f ! -type l 2>/dev/null | head -1)
            if [ -n "$real_files" ]; then
                needs_repair=true
                break
            fi
        fi
    done

    if [ "$needs_repair" = true ]; then
        python3 "$VAULT_PATH/sync.py" --merge --repo "$REPO_NAME" >/dev/null 2>&1
    fi
fi
